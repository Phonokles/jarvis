{
  "name": "jarvis-ui",
  "version": "1.0.0",
  "description": "JARVIS Desktop Interface",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --linux"
  },
  "build": {
    "appId": "com.jarvis.ai",
    "productName": "JARVIS",
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png",
      "category": "Utility"
    },
    "files": ["src/**/*", "assets/**/*"]
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.0.0"
  }
}
